VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-key

# Supabase server-side values for Netlify functions.
# SUPABASE_SERVICE_ROLE_KEY is preferred in production; never expose it in frontend code.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend — email notifications for build requests and wishes
# Get your API key at resend.com
RESEND_API_KEY=re_your_api_key_here
RESEND_TO_EMAIL=ishmael@appsdepot.app
RESEND_FROM_EMAIL=ishmael@appsdepot.app
