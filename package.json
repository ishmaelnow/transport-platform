{
  "name": "transport-platform",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.15.0",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "dev:admin": "pnpm --filter @transport-platform/admin dev",
    "dev:rider": "pnpm --filter @transport-platform/rider dev",
    "dev:driver": "pnpm --filter @transport-platform/driver dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "turbo run lint",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:status": "supabase status",
    "supabase:types": "supabase gen types typescript --local > packages/platform/supabase/src/database.types.ts",
    "test": "turbo run test",
    "test:e2e": "playwright test",
    "typecheck": "turbo run typecheck",
    "validate": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test"
  },
  "pnpm": {
    "overrides": {
      "@supabase/storage-js": "2.10.4"
    }
  },
  "devDependencies": {
    "@eslint/js": "9.32.0",
    "@next/eslint-plugin-next": "16.2.10",
    "@playwright/test": "1.54.0",
    "@types/node": "20.19.0",
    "@types/react": "19.1.0",
    "@types/react-dom": "19.1.0",
    "eslint": "9.32.0",
    "eslint-config-next": "16.2.10",
    "prettier": "3.6.0",
    "turbo": "2.5.0",
    "typescript": "5.8.3",
    "typescript-eslint": "8.38.0",
    "vitest": "3.2.0"
  }
}
