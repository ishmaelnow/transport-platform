{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "verbatimModuleSyntax": true,
    "baseUrl": ".",
    "paths": {
      "@esh-platform/auth": ["packages/platform/auth/src/index.ts"],
      "@esh-platform/config": ["packages/platform/config/src/index.ts"],
      "@esh-platform/events": ["packages/platform/events/src/index.ts"],
      "@esh-platform/logger": ["packages/platform/logger/src/index.ts"],
      "@esh-platform/stripe": ["packages/platform/stripe/src/index.ts"],
      "@esh-platform/supabase": ["packages/platform/supabase/src/index.ts"],
      "@esh-platform/testing": ["packages/platform/testing/src/index.ts"],
      "@esh-platform/workflows": ["packages/platform/workflows/src/index.ts"]
    }
  }
}
